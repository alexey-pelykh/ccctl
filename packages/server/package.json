{
  "name": "@ccctl/server",
  "version": "0.0.0",
  "description": "ccctl local server: accepts the patched Claude Code worker stream-json channel, relays to UI over SSE + fetch",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Alexey Pelykh (https://github.com/alexey-pelykh)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^25",
    "eslint": "^10.4.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ccctl/core": "workspace:*"
  }
}
