{
  "name": "ccctl-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --concurrency=1",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm format:check && turbo run lint && pnpm lint:root",
    "lint:root": "eslint eslint.config.js",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "@tony.ganchev/eslint-plugin-header": "^3.3.3",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
